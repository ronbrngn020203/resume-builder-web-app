@using System.Security.Claims
@{
    var user = Context.User;
    var role = user?.FindFirst(ClaimTypes.Role)?.Value ?? "";
    string dashboardController = role switch
    {
        "Admin" => "AdminDashboard",
        "Staff" => "StaffDashboard",
        "Graduate" => "GraduateDashboard",
        _ => "Account"
    };
}

@model IEnumerable<ResumeBuilderWebApp.Models.User>

@{
    ViewData["Title"] = "Users Management";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary">Manage Users</h2>
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Create New
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center">
            No users found. Click <strong>Create New</strong> to add one.
        </div>
    }
    else
    {
        <div class="table-responsive shadow-sm">
            <table class="table table-bordered table-hover align-middle mb-0">
                <thead class="table-primary">
                    <tr>
                        <th>@Html.DisplayNameFor(model => model.FullName)</th>
                        <th>@Html.DisplayNameFor(model => model.Email)</th>
                        <th>@Html.DisplayNameFor(model => model.Role)</th>
                        <th>@Html.DisplayNameFor(model => model.CreatedAt)</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.FullName</td>
                            <td>@item.Email</td>
                            <td>@item.Role</td>
                            <td>@item.CreatedAt.ToString("dd MMM yyyy")</td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@item.UserId" class="btn btn-warning btn-sm me-1">Edit</a>
                                <a asp-action="Details" asp-route-id="@item.UserId" class="btn btn-info btn-sm me-1">Details</a>
                                <a asp-action="Delete" asp-route-id="@item.UserId" class="btn btn-danger btn-sm">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <div class="mt-4 text-center">
        <a asp-controller="@dashboardController" asp-action="Index" class="btn btn-secondary">Back to Dashboard</a>
    </div>
</div>