@model IEnumerable<ResumeBuilderWebApp.Models.Resume>

@{
    ViewData["Title"] = "Your Resumes";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold">My Resumes</h2>
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Create New Resume
        </a>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row">
            @foreach (var resume in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body">
                            <h5 class="card-title">
                                <a asp-action="Preview" asp-route-id="@resume.ResumeId" class="text-decoration-none text-primary fw-bold">
                                    @resume.Title
                                </a>
                            </h5>
                            <p class="fw-semibold mb-1">@resume.FullName</p>
                            <p class="mb-1 text-muted small">@resume.Email</p>
                            <p class="text-secondary small mb-2">
                                <i class="bi bi-clock"></i> Created @resume.CreatedAt.ToString("dd MMM yyyy")
                            </p>

                            <div class="d-flex justify-content-between mt-3">
                                <a asp-action="Preview" asp-route-id="@resume.ResumeId" class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-eye"></i> View
                                </a>
                                <a asp-action="Edit" asp-route-id="@resume.ResumeId" class="btn btn-outline-warning btn-sm">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <a asp-action="Delete" asp-route-id="@resume.ResumeId" class="btn btn-outline-danger btn-sm">
                                    <i class="bi bi-trash"></i> Delete
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info text-center">
            <i class="bi bi-info-circle"></i> No resumes found.
            <a asp-action="Create" class="alert-link">Create one now!</a>
        </div>
    }
</div>
