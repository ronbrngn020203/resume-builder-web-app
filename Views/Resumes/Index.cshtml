@model IEnumerable<ResumeBuilderWebApp.Models.Resume>

@{
    ViewData["Title"] = "Your Resumes";
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-3 rb-page-header">
    <div>
        <span class="rb-eyebrow">● Resumes</span>
        <h2 class="mb-0">My resumes</h2>
    </div>
    <a asp-action="Create" class="btn btn-accent">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px;vertical-align:-2px;margin-right:4px;"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
        Create new resume
    </a>
</div>

@if (Model != null && Model.Any())
{
    <div class="row">
        @foreach (var resume in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">
                            <a asp-action="Preview" asp-route-id="@resume.ResumeId" class="text-decoration-none">
                                @resume.Title
                            </a>
                        </h5>
                        <p class="fw-semibold mb-1">@resume.FullName</p>
                        <p class="mb-1 text-muted small" style="color: var(--slate) !important;">@resume.Email</p>
                        <p class="small mb-3" style="color: var(--slate);">
                            Created @resume.CreatedAt.ToString("dd MMM yyyy")
                        </p>

                        <div class="d-flex justify-content-between gap-2">
                            <a asp-action="Preview" asp-route-id="@resume.ResumeId" class="btn btn-outline-primary btn-sm flex-fill">
                                View
                            </a>
                            <a asp-action="Edit" asp-route-id="@resume.ResumeId" class="btn btn-outline-primary btn-sm flex-fill">
                                Edit
                            </a>
                            <a asp-action="Delete" asp-route-id="@resume.ResumeId" class="btn btn-outline-danger btn-sm flex-fill">
                                Delete
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="rb-empty-state">
        <p class="mb-3">You haven't created any resumes yet.</p>
        <a asp-action="Create" class="btn btn-accent">Create your first resume</a>
    </div>
}