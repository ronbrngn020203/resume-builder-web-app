@{
    ViewData["Title"] = "Home";
}

<div class="text-center py-5 bg-light rounded shadow-sm">
    <h1 class="display-4 text-primary fw-bold">Welcome to Resume Builder</h1>
    <p class="lead mb-5">Create, manage, and perfect your professional resume with ease.</p>

    <div class="d-flex justify-content-center gap-3">
        <a asp-controller="Services" asp-action="Index" class="btn btn-primary btn-lg">
            Browse Services
        </a>
        <a asp-controller="AdminServices" asp-action="Index" class="btn btn-outline-primary btn-lg">
            Manage Services
        </a>
        <a asp-controller="Users" asp-action="Index" class="btn btn-outline-dark btn-lg">
            Manage Users
        </a>
    </div>
</div>
