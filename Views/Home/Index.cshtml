@using System.Security.Claims
@{
    ViewData["Title"] = "Home";
    var isAuthenticated = Context.User.Identity?.IsAuthenticated ?? false;
    var role = Context.User?.FindFirst(ClaimTypes.Role)?.Value ?? "";
    string ctaController = role switch
    {
        "Admin" => "AdminDashboard",
        "Graduate" => "GraduateDashboard",
        _ => "Account"
    };
    string ctaAction = isAuthenticated ? "Index" : "Login";
    string ctaLabel = isAuthenticated ? "Go to my dashboard" : "Get started — it's free";
}

<div class="rb-hero">
    <div class="row align-items-center g-5">
        <div class="col-lg-7">
            <span class="rb-hero-eyebrow">● Built for job-seeking graduates</span>
            <h1>Turn your coursework into a resume that gets you hired.</h1>
            <p class="lead mb-4">
                Build a clean, professional resume in minutes, then book career services
                to help you land your first role.
            </p>
            <div class="d-flex gap-3 flex-wrap">
                <a asp-controller="@ctaController" asp-action="@ctaAction" class="btn btn-accent btn-lg">
                    @ctaLabel
                </a>
                <a asp-controller="Services" asp-action="Index" class="btn btn-outline-light btn-lg">
                    Browse services
                </a>
            </div>
        </div>
        <div class="col-lg-5 d-none d-lg-block">
            <div class="rb-card-stack">
                <div class="rb-card">
                    <div class="rb-line accent"></div>
                    <div class="rb-line"></div>
                    <div class="rb-line short"></div>
                </div>
                <div class="rb-card">
                    <div class="rb-line accent"></div>
                    <div class="rb-line"></div>
                    <div class="rb-line short"></div>
                </div>
                <div class="rb-card">
                    <div class="rb-line accent"></div>
                    <div class="rb-line"></div>
                    <div class="rb-line"></div>
                    <div class="rb-line short"></div>
                </div>
            </div>
        </div>
    </div>
</div>