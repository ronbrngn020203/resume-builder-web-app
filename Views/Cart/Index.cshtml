@model List<ResumeBuilderWebApp.Models.CartItem>

@{
    ViewData["Title"] = "My Cart";
}

<div class="container mt-5">
    <h2 class="text-primary mb-4">🛒 My Cart</h2>

    @if (Model != null && Model.Any())
    {
        <table class="table table-striped">
            <thead class="table-dark">
                <tr>
                    <th>Service</th>
                    <th>Price</th>
                    <th>Quantity</th>
                    <th>Total</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Title</td>
                        <td>$@item.Price</td>
                        <td>@item.Quantity</td>
                        <td>$@item.Total</td>
                        <td>
                            <form asp-action="Remove" method="post">
                                <input type="hidden" name="id" value="@item.ServiceId" />
                                <button type="submit" class="btn btn-danger btn-sm">Remove</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <h4 class="text-end">Total: <strong>$@ViewBag.Total</strong></h4>

        <form asp-action="Clear" method="post" class="text-end mt-3">
            <button type="submit" class="btn btn-outline-danger">Clear Cart</button>
        </form>
    }
    else
    {
        <div class="alert alert-info text-center">
            Your cart is empty.
            <a asp-controller="Services" asp-action="Index" class="alert-link">Browse services</a>
        </div>
    }
</div>
