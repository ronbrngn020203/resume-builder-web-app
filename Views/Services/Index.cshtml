@using System.Security.Claims
@{
    var user = Context.User;
    var role = user?.FindFirst(ClaimTypes.Role)?.Value ?? "";
    string dashboardController = role switch
    {
        "Admin" => "AdminDashboard",
        "Graduate" => "GraduateDashboard",
        _ => "Account"
    };
}

@model IEnumerable<ResumeBuilderWebApp.Models.ServiceCategory>

@{
    ViewData["Title"] = "Browse Services";
}

<div class="rb-page-header">
    <span class="rb-eyebrow">● Services</span>
    <h2>Browse services</h2>
    <p class="lead mb-0">Pick a category to see what's on offer.</p>
</div>

<div class="row">
    @foreach (var category in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body">
                    <div class="rb-icon-tile indigo">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 7h-9"></path><path d="M14 17H5"></path><circle cx="17" cy="17" r="3"></circle><circle cx="7" cy="7" r="3"></circle></svg>
                    </div>
                    <h4 class="card-title">@category.Name</h4>
                    <p class="card-text text-muted" style="color: var(--slate) !important;">@category.Description</p>
                    <a asp-action="Category" asp-route-slug="@category.Slug"
                       class="btn btn-outline-primary">
                        View services
                    </a>
                </div>
            </div>
        </div>
    }
</div>

<div class="mt-3">
    <a asp-controller="@dashboardController" asp-action="Index">← Back to home</a>
</div>