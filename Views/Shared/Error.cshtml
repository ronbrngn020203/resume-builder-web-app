@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="container text-center mt-5">
    <h1 class="text-danger">⚠️ Something went wrong</h1>
    <p class="lead">We encountered an unexpected error while processing your request.</p>

    @if (Model?.RequestId != null)
    {
        <p class="text-muted"><strong>Error ID:</strong> @Model.RequestId</p>
    }

    <div class="mt-4">
        <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg">
            Return to Login
        </a>
    </div>

    <hr class="my-4" />

    <p class="small text-muted">
        If this issue continues, please contact our support team.
    </p>
</div>
