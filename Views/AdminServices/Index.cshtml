@using System.Security.Claims
@{
    var user = Context.User;
    var role = user?.FindFirst(ClaimTypes.Role)?.Value ?? "";
    string dashboardController = role switch
    {
        "Admin" => "AdminDashboard",
        "Graduate" => "GraduateDashboard",
        _ => "Account"
    };
}

@model IEnumerable<ResumeBuilderWebApp.Models.Service>

@{
    ViewData["Title"] = "Services Management";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary">Manage Services</h2>
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Create New
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center">
            No services available yet. Click <strong>Create New</strong> to add one.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card shadow-sm h-100">
                        <img src="@item.ThumbnailPath" class="card-img-top" alt="@item.Title"
                             style="height:200px; object-fit:cover;" />
                        <div class="card-body">
                            <h5 class="card-title">@item.Title</h5>
                            <p class="card-text text-muted">@item.ShortDescription</p>
                            <p class="mb-1"><strong>Category:</strong> @item.Category?.Name</p>
                            <p><strong>Price:</strong> $@item.Price</p>
                        </div>
                        <div class="card-footer text-center">
                            <a asp-action="Edit" asp-route-id="@item.ServiceId" class="btn btn-warning btn-sm me-1">Edit</a>
                            <a asp-action="Details" asp-route-id="@item.ServiceId" class="btn btn-info btn-sm me-1">Details</a>
                            <a asp-action="Delete" asp-route-id="@item.ServiceId" class="btn btn-danger btn-sm">Delete</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <div class="mt-4 text-center">
        <a asp-controller="@dashboardController" asp-action="Index" class="btn btn-secondary">Back to Dashboard</a>
    </div>
</div>

