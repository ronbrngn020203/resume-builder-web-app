@using System.Security.Claims
@{
    var user = Context.User;
    var role = user?.FindFirst(ClaimTypes.Role)?.Value ?? "";
    string dashboardController = role switch
    {
        "Admin" => "AdminDashboard",
        "Graduate" => "GraduateDashboard",
        _ => "Account"
    };
}

@model IEnumerable<ResumeBuilderWebApp.Models.Service>

@{
    ViewData["Title"] = "Services Management";
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-3 rb-page-header">
    <div>
        <span class="rb-eyebrow">● Admin</span>
        <h2 class="mb-0">Manage services</h2>
    </div>
    <a asp-action="Create" class="btn btn-accent">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px;vertical-align:-2px;margin-right:4px;"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
        Create new service
    </a>
</div>

@if (!Model.Any())
{
    <div class="rb-empty-state">
        <p class="mb-3">No services available yet.</p>
        <a asp-action="Create" class="btn btn-accent">Create the first service</a>
    </div>
}
else
{
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    <img src="@item.ThumbnailPath" class="card-img-top" alt="@item.Title"
                         style="height:180px; object-fit:cover; border-radius: var(--radius-md) var(--radius-md) 0 0;" />
                    <div class="card-body">
                        <h5 class="card-title">@item.Title</h5>
                        <p class="card-text text-muted" style="color: var(--slate) !important;">@item.ShortDescription</p>
                        <p class="mb-1 small" style="color: var(--slate);"><strong>Category:</strong> @item.Category?.Name</p>
                        <p class="fw-bold mb-0" style="color: var(--indigo);">$@item.Price</p>
                    </div>
                    <div class="card-footer bg-transparent border-top-0 pb-3 d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@item.ServiceId" class="btn btn-outline-primary btn-sm flex-fill">Edit</a>
                        <a asp-action="Details" asp-route-id="@item.ServiceId" class="btn btn-outline-primary btn-sm flex-fill">Details</a>
                        <a asp-action="Delete" asp-route-id="@item.ServiceId" class="btn btn-outline-danger btn-sm flex-fill">Delete</a>
                    </div>
                </div>
            </div>
        }
    </div>
}

<div class="mt-4">
    <a asp-controller="@dashboardController" asp-action="Index" class="btn btn-outline-primary">← Back to dashboard</a>
</div>